{% extends 'base.html.twig' %}

{% block title %}About - Student Management System{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <h1 class="mb-4">About Student Management System</h1>
        
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title">Project Overview</h5>
                <p class="card-text">
                    The <strong>Student Management System</strong> is a comprehensive web application 
                    built using PHP 8 and the Symfony Framework. It provides a centralized platform 
                    for managing students, academic departments, courses, and student enrollments.
                </p>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title">Key Features</h5>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <i class="bi bi-check-circle-fill text-success"></i> 
                        Student profile management with personal information
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle-fill text-success"></i> 
                        Department organization and course catalog
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle-fill text-success"></i> 
                        Course enrollment and grade tracking
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle-fill text-success"></i> 
                        Responsive design for desktop, tablet, and mobile
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle-fill text-success"></i> 
                        RESTful architecture with clean URLs
                    </li>
                </ul>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title">Technology Stack</h5>
                <div class="row">
                    <div class="col-md-6">
                        <h6>Backend</h6>
                        <ul>
                            <li>PHP 8</li>
                            <li>Symfony Framework</li>
                            <li>Doctrine ORM</li>
                            <li>MySQL Database</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <h6>Frontend</h6>
                        <ul>
                            <li>HTML5 & CSS3</li>
                            <li>Bootstrap 5</li>
                            <li>Twig Templating</li>
                            <li>JavaScript (ES6+)</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Contact Information</h5>
                <p class="card-text">
                    For questions, feedback, or support, please contact the development team:
                </p>
                <p>
                    <i class="bi bi-envelope"></i> Email: 
                    <a href="mailto:support@studentms.edu">support@studentms.edu</a>
                </p>
            </div>
        </div>

        <div class="text-center mt-4">
            <a href="{{ path('app_home') }}" class="btn btn-secondary">
                ← Back to Home
            </a>
        </div>
    </div>
</div>
{% endblock %}