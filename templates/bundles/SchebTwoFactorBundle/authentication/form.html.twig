{% extends 'base.html.twig' %}

{% block title %}Authentication Required - Student Management System{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
  @import url('https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

  :root {
    --primary:       #4f46e5;
    --primary-light: #6366f1;
    --primary-dark:  #3730a3;
    --accent:        #06b6d4;
    --surface:       #0f172a;
    --surface-2:     #1e293b;
    --surface-3:     #334155;
    --border:        rgba(99, 102, 241, 0.25);
    --text-primary:  #f1f5f9;
    --text-secondary:#94a3b8;
    --text-muted:    #64748b;
    --danger:        #ef4444;
    --danger-bg:     rgba(239, 68, 68, 0.10);
    --success:       #10b981;
    --glow:          rgba(79, 70, 229, 0.35);
  }

  body {
    font-family: 'Sora', sans-serif;
    background: var(--surface) !important;
    color: var(--text-primary);
    min-height: 100vh;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow-x: hidden;
  }
  
  main.container {
    max-width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  nav.navbar, footer { display: none !important; }

  .bg-grid {
    position: fixed; inset: 0; z-index: 0;
    background-image:
      linear-gradient(rgba(99,102,241,.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99,102,241,.06) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
  }

  .bg-orbs {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
  }
  .orb {
    position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.18;
    animation: orb-drift 18s ease-in-out infinite alternate;
  }
  .orb-1 { width: 520px; height: 520px; background: var(--primary); top: -160px; left: -160px; }
  .orb-2 { width: 400px; height: 400px; background: var(--accent); bottom: -120px; right: -100px; }

  @keyframes orb-drift {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(40px, 30px) scale(1.08); }
  }

  .login-wrapper {
    position: relative; z-index: 10;
    width: 100%; max-width: 440px;
    padding: 20px;
    animation: card-in .6s cubic-bezier(.16,1,.3,1) both;
  }

  @keyframes card-in {
    from { opacity: 0; transform: translateY(28px) scale(.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .login-card {
    background: rgba(30, 41, 59, 0.70);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 44px 40px 40px;
    backdrop-filter: blur(20px);
    box-shadow: 0 32px 64px rgba(0,0,0,.45), 0 0 80px var(--glow);
  }

  .brand {
    display: flex; align-items: center; gap: 12px; margin-bottom: 32px;
  }
  .brand-icon {
    width: 42px; height: 42px; border-radius: 12px;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    display: flex; align-items: center; justify-content: center;
  }
  .brand-icon i { color: #fff; font-size: 1.2rem; }
  .brand-name {
    font-size: .85rem; font-weight: 600; letter-spacing: .1em;
    text-transform: uppercase; color: var(--text-secondary);
    font-family: 'JetBrains Mono', monospace;
  }

  .heading h1 {
    font-size: 1.5rem; font-weight: 700; color: var(--text-primary);
  }
  .heading p { font-size: .875rem; color: var(--text-muted); margin-top: 8px; }

  .alert {
    background: var(--danger-bg); border: 1px solid rgba(239,68,68,.3);
    color: #fca5a5; padding: 12px; border-radius: 10px; font-size: .83rem; margin-bottom: 20px;
    display: flex; align-items: center; gap: 10px;
  }

  .form { margin-top: 28px; display: flex; flex-direction: column; gap: 24px; }
  
  .auth-input {
    width: 100%;
    background: rgba(15,23,42,.55);
    border: 2px solid var(--surface-3);
    border-radius: 12px;
    color: var(--primary-light);
    font-family: 'JetBrains Mono', monospace;
    font-size: 2.2rem;
    font-weight: 700;
    text-align: center;
    letter-spacing: 12px;
    padding: 15px;
    outline: none;
    transition: all .2s;
  }

  .btn-submit {
    width: 100%;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
    border: none; border-radius: 10px;
    color: #fff; font-size: .95rem; font-weight: 600;
    padding: 14px; cursor: pointer;
    box-shadow: 0 4px 20px var(--glow);
  }

  .footer-links { margin-top: 25px; text-align: center; font-size: .8rem; color: var(--text-muted); }
  .footer-links a { color: var(--text-secondary); text-decoration: none; }
</style>
{% endblock %}

{% block body %}
<div class="bg-grid"></div>
<div class="bg-orbs">
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
</div>

<div class="login-wrapper">
  <div class="login-card">
    <div class="brand">
      <div class="brand-icon">
        <i class="bi bi-shield-lock-fill"></i>
      </div>
      <span class="brand-name">Security Check</span>
    </div>

    <div class="heading">
      <h1>Verify Identity</h1>
      <p>Enter the 6-digit security code from your email.</p>
    </div>

    {% if authenticationError %}
        <div class="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>{{ authenticationErrorData|trans(authenticationError, 'SchebTwoFactorBundle')|default('Invalid code. Please try again.') }}</span>
        </div>
    {% endif %}

    {# Sử dụng trực tiếp đường dẫn xử lý mã xác nhận #}
    <form action="{{ path('2fa_login_check') }}" method="post" class="form">
      
      <div class="auth-input-container">
        <input id="_auth_code" 
               type="text" 
               name="_auth_code" 
               class="auth-input" 
               placeholder="000000" 
               maxlength="6"
               inputmode="numeric" 
               pattern="[0-9]*" 
               required 
               autofocus>
      </div>

      {# Ép buộc Symfony biết trang đích sau khi thành công #}
      <input type="hidden" name="_target_path" value="{{ path('home') }}" />

      <button type="submit" class="btn-submit">
        Confirm Code <i class="bi bi-arrow-right-short ms-1"></i>
      </button>

      <div class="footer-links">
        <a href="{{ path('app_logout') }}">
             <i class="bi bi-arrow-left me-1"></i> Back to Login
        </a>
      </div>
    </form>
  </div>
</div>
{% endblock %}