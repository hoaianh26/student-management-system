{% extends 'base.html.twig' %}

{% block title %}Sign In - Student Management System{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
  @import url('https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

  :root {
    --primary:       #4f46e5;
    --primary-light: #6366f1;
    --primary-dark:  #3730a3;
    --accent:        #06b6d4;
    --surface:       #0f172a;
    --surface-2:     #1e293b;
    --surface-3:     #334155;
    --border:        rgba(99, 102, 241, 0.25);
    --text-primary:  #f1f5f9;
    --text-secondary:#94a3b8;
    --text-muted:    #64748b;
    --danger:        #ef4444;
    --danger-bg:     rgba(239, 68, 68, 0.10);
    --success:       #10b981;
    --glow:          rgba(79, 70, 229, 0.35);
  }

  /* Reset layout constraints from base.html.twig for login page */
  body {
    font-family: 'Sora', sans-serif;
    background: var(--surface) !important;
    color: var(--text-primary);
    min-height: 100vh;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow-x: hidden;
  }
  
  main.container {
    max-width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 80vh;
  }

  /* Hide navbar and footer on login page for clean look */
  nav.navbar, footer { display: none !important; }

  /* ── Animated background ── */
  .bg-grid {
    position: fixed; inset: 0; z-index: 0;
    background-image:
      linear-gradient(rgba(99,102,241,.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99,102,241,.06) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
  }

  .bg-orbs {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
  }
  .orb {
    position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.18;
    animation: orb-drift 18s ease-in-out infinite alternate;
  }
  .orb-1 { width: 520px; height: 520px; background: var(--primary); top: -160px; left: -160px; animation-delay: 0s; }
  .orb-2 { width: 400px; height: 400px; background: var(--accent); bottom: -120px; right: -100px; animation-delay: -6s; }
  .orb-3 { width: 300px; height: 300px; background: var(--primary-light); top: 40%; left: 55%; animation-delay: -12s; }

  @keyframes orb-drift {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(40px, 30px) scale(1.08); }
  }

  /* ── Card ── */
  .login-wrapper {
    position: relative; z-index: 10;
    width: 100%; max-width: 440px;
    padding: 20px;
    animation: card-in .6s cubic-bezier(.16,1,.3,1) both;
  }

  @keyframes card-in {
    from { opacity: 0; transform: translateY(28px) scale(.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .login-card {
    background: rgba(30, 41, 59, 0.70);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 44px 40px 40px;
    backdrop-filter: blur(20px);
    box-shadow:
      0 0 0 1px rgba(255,255,255,.04) inset,
      0 32px 64px rgba(0,0,0,.45),
      0 0 80px var(--glow);
  }

  /* ── Brand mark ── */
  .brand {
    display: flex; align-items: center; gap: 12px; margin-bottom: 32px;
  }
  .brand-icon {
    width: 42px; height: 42px; border-radius: 12px;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 16px var(--glow);
  }
  .brand-icon i { color: #fff; font-size: 1.2rem; }
  .brand-name {
    font-size: .85rem; font-weight: 600; letter-spacing: .1em;
    text-transform: uppercase; color: var(--text-secondary);
    font-family: 'JetBrains Mono', monospace;
  }

  /* ── Heading ── */
  .heading { margin-bottom: 8px; }
  .heading h1 {
    font-size: 1.6rem; font-weight: 700; letter-spacing: -.02em;
    color: var(--text-primary);
    line-height: 1.2;
  }
  .heading p { font-size: .875rem; color: var(--text-muted); margin-top: 6px; }

  /* ── Already logged in ── */
  .logged-in-notice {
    display: flex; align-items: center; gap: 10px;
    background: rgba(16,185,129,.10);
    border: 1px solid rgba(16,185,129,.25);
    border-radius: 10px;
    padding: 12px 16px;
    margin-bottom: 20px;
    font-size: .83rem; color: var(--success);
  }
  .logged-in-notice a {
    color: var(--success); font-weight: 600;
    text-decoration: underline; text-underline-offset: 2px;
  }

  /* ── Alerts ── */
  .alert {
    display: flex; align-items: flex-start; gap: 10px;
    border-radius: 10px; padding: 12px 16px; margin-bottom: 20px;
    font-size: .83rem; line-height: 1.5;
  }
  .alert-danger {
    background: var(--danger-bg); border: 1px solid rgba(239,68,68,.3);
    color: #fca5a5;
  }

  /* ── Form ── */
  .form { margin-top: 28px; display: flex; flex-direction: column; gap: 20px; }
  .field { display: flex; flex-direction: column; gap: 7px; }
  .field label {
    font-size: .78rem; font-weight: 500; letter-spacing: .04em;
    text-transform: uppercase; color: var(--text-secondary);
  }

  .input-wrap { position: relative; }
  .input-icon {
    position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
    color: var(--text-muted); pointer-events: none;
  }

  .field input {
    width: 100%;
    background: rgba(15,23,42,.55);
    border: 1px solid var(--surface-3);
    border-radius: 10px;
    color: var(--text-primary);
    font-family: 'Sora', sans-serif;
    font-size: .9rem;
    padding: 11px 44px 11px 42px;
    outline: none;
    transition: all .2s;
  }
  .field input:focus {
    border-color: var(--primary-light);
    box-shadow: 0 0 0 3px rgba(99,102,241,.18);
    background: rgba(15,23,42,.8);
  }

  .pw-toggle {
    position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
    background: none; border: none; cursor: pointer;
    color: var(--text-muted); padding: 4px;
  }

  .btn-submit {
    width: 100%;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
    border: none; border-radius: 10px;
    color: #fff; font-size: .9rem; font-weight: 600;
    padding: 13px; margin-top: 10px;
    cursor: pointer;
    transition: all .2s;
    box-shadow: 0 4px 20px var(--glow);
  }
  .btn-submit:hover { transform: translateY(-1px); box-shadow: 0 8px 28px var(--glow); opacity: 0.95; }
</style>
{% endblock %}

{% block body %}
<div class="bg-grid"></div>
<div class="bg-orbs">
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
</div>

<div class="login-wrapper">
  <div class="login-card">
    <div class="brand">
      <div class="brand-icon">
        <i class="bi bi-mortarboard-fill"></i>
      </div>
      <span class="brand-name">Student System</span>
    </div>

    <div class="heading">
      <h1>Welcome back</h1>
      <p>Sign in to manage your institution.</p>
    </div>

    {% if app.user %}
      <div class="logged-in-notice">
        <i class="bi bi-check-circle-fill"></i>
        <span>Signed in as <strong>{{ app.user.userIdentifier }}</strong>.</span>
        <a href="{{ logout_path() }}" class="ms-auto">Sign out</a>
      </div>
    {% endif %}

    {% if error %}
      <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle-fill mt-1"></i>
        <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
      </div>
    {% endif %}

    <form method="post" class="form">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

      <div class="field">
        <label for="username">Email Address</label>
        <div class="input-wrap">
          <span class="input-icon"><i class="bi bi-envelope"></i></span>
          <input type="email" id="username" name="_username" value="{{ last_username }}" placeholder="you@example.com" required autofocus>
        </div>
      </div>

      <div class="field">
        <label for="password">Password</label>
        <div class="input-wrap">
          <span class="input-icon"><i class="bi bi-lock"></i></span>
          <input type="password" id="password" name="_password" placeholder="••••••••" required>
          <button type="button" class="pw-toggle" onclick="togglePassword()">
            <i id="eye-icon" class="bi bi-eye"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="btn-submit">
        Sign in <i class="bi bi-arrow-right-short ms-1"></i>
      </button>

      <div class="text-center mt-4">
        <a href="{{ path('home') }}" class="text-decoration-none small text-muted">
           <i class="bi bi-house-door me-1"></i> Back to Home
        </a>
      </div>
    </form>
  </div>
</div>

<script>
  function togglePassword() {
    const pw = document.getElementById('password');
    const icon = document.getElementById('eye-icon');
    if (pw.type === 'password') {
      pw.type = 'text';
      icon.classList.replace('bi-eye', 'bi-eye-slash');
    } else {
      pw.type = 'password';
      icon.classList.replace('bi-eye-slash', 'bi-eye');
    }
  }
</script>
{% endblock %}