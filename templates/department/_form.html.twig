{{ form_start(form) }}
    <div class="row">
        <div class="col-md-6 mb-3">
            {{ form_row(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Enter department name'}}) }}
        </div>
        <div class="col-md-6 mb-3">
            {{ form_row(form.code, {'attr': {'class': 'form-control', 'placeholder': 'DEPT-01'}}) }}
        </div>
        <div class="col-12 mb-3">
            {{ form_row(form.description, {'attr': {'class': 'form-control', 'rows': 4, 'placeholder': 'Optional description...'}}) }}
        </div>
    </div>
    <div class="d-flex justify-content-end gap-2 mt-3">
        <a href="{{ path('department_index') }}" class="btn btn-secondary">
            <i class="bi bi-x-circle"></i> Cancel
        </a>
        <button class="btn btn-success">
            <i class="bi bi-check-circle"></i> {{ button_label|default('Save Changes') }}
        </button>
    </div>
{{ form_end(form) }}
