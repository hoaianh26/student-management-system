{% extends 'base.html.twig' %}

{% block title %}{{ department.name }} - Student Management System{% endblock %}

{% block body %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('home') }}">Home</a></li>
        <li class="breadcrumb-item"><a href="{{ path('department_index') }}">Departments</a></li>
        <li class="breadcrumb-item active">{{ department.name }}</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>
        <i class="bi bi-building"></i> {{ department.name }}
        <span class="badge bg-success">{{ department.code }}</span>
    </h1>
    {% if is_granted('ROLE_ADMIN') %}
    <a href="{{ path('department_edit', {id: department.id}) }}" class="btn btn-warning">
        <i class="bi bi-pencil"></i> Edit
    </a>
    {% endif %}
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title">Description</h5>
        <p>{{ department.description|default('No description available.') }}</p>
    </div>
</div>

<div class="row">
    {# Students in this Department #}
    <div class="col-lg-6 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Students ({{ department.students|length }})</h5>
            </div>
            <div class="card-body">
                {% if department.students is empty %}
                    <p class="text-muted">No students in this department.</p>
                {% else %}
                    <div class="list-group">
                        {% for student in department.students|slice(0, 10) %}
                        <a href="{{ path('student_show', {id: student.id}) }}" 
                           class="list-group-item list-group-item-action">
                            {{ student.firstName }} {{ student.lastName }}
                            <small class="text-muted">({{ student.email }})</small>
                        </a>
                        {% endfor %}
                    </div>
                    {% if department.students|length > 10 %}
                        <p class="text-muted mt-2 small">
                            ... and {{ department.students|length - 10 }} more
                        </p>
                    {% endif %}
                {% endif %}
            </div>
        </div>
    </div>

    {# Courses in this Department #}
    <div class="col-lg-6 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-warning">
                <h5 class="mb-0">Courses ({{ department.courses|length }})</h5>
            </div>
            <div class="card-body">
                {% if department.courses is empty %}
                    <p class="text-muted">No courses offered by this department.</p>
                {% else %}
                    <div class="list-group">
                        {% for course in department.courses %}
                        <a href="{{ path('course_show', {id: course.id}) }}" 
                           class="list-group-item list-group-item-action">
                            <div class="d-flex justify-content-between">
                                <span>{{ course.name }}</span>
                                <span class="badge bg-info">{{ course.code }}</span>
                            </div>
                            <small class="text-muted">Credits: {{ course.credits }}</small>
                        </a>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}