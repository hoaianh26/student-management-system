{% extends 'base.html.twig' %}

{% block title %}Departments - Student Management System{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-building"></i> Departments</h1>
    {% if is_granted('ROLE_ADMIN') %}
    <a href="{{ path('department_new') }}" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Add Department
    </a>
    {% endif %}
</div>

{% if departments is empty %}
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No departments found.
    </div>
{% else %}
    <div class="row">
        {% for department in departments %}
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        {{ department.name }}
                        <span class="badge bg-success">{{ department.code }}</span>
                    </h5>
                    <p class="card-text text-muted">
                        {{ department.description|default('No description available.')|slice(0, 100) }}
                        {% if department.description|length > 100 %}...{% endif %}
                    </p>
                    <hr>
                    <div class="d-flex justify-content-between text-muted small">
                        <span>
                            <i class="bi bi-people"></i> 
                            {{ department.students|length }} students
                        </span>
                        <span>
                            <i class="bi bi-book"></i> 
                            {{ department.courses|length }} courses
                        </span>
                    </div>
                </div>
                <div class="card-footer bg-transparent">
                    <a href="{{ path('department_show', {id: department.id}) }}" class="btn btn-sm btn-outline-success w-100">
                        <i class="bi bi-eye"></i> View Details
                    </a>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}