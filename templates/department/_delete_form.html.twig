<form method="post" action="{{ path('app_department_delete', {'id': department.id}) }}" onsubmit="return confirm('Are you sure you want to delete this department?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ department.id) }}">
    <button class="btn btn-outline-danger">
        <i class="bi bi-trash"></i> Delete Department
    </button>
</form>
