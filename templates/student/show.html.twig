{% extends 'base.html.twig' %}

{% block title %}{{ student.firstName }} {{ student.lastName }} - Student Management System{% endblock %}

{% block body %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('home') }}">Home</a></li>
        <li class="breadcrumb-item"><a href="{{ path('student_index') }}">Students</a></li>
        <li class="breadcrumb-item active">{{ student.firstName }} {{ student.lastName }}</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>
        <i class="bi bi-person-circle"></i> 
        {{ student.firstName }} {{ student.lastName }}
    </h1>
    {% if is_granted('ROLE_ADMIN') %}
    <div>
        <a href="{{ path('student_edit', {id: student.id}) }}" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
            <i class="bi bi-trash"></i> Delete
        </button>
    </div>
    {% endif %}
</div>

<div class="row">
    {# Personal Information Card #}
    <div class="col-lg-6 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Personal Information</h5>
            </div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tr>
                        <td class="text-muted" style="width: 40%;"><strong>Student ID:</strong></td>
                        <td><span class="badge bg-secondary">{{ student.id }}</span></td>
                    </tr>
                    <tr>
                        <td class="text-muted"><strong>First Name:</strong></td>
                        <td>{{ student.firstName }}</td>
                    </tr>
                    <tr>
                        <td class="text-muted"><strong>Last Name:</strong></td>
                        <td>{{ student.lastName }}</td>
                    </tr>
                    <tr>
                        <td class="text-muted"><strong>Email:</strong></td>
                        <td>
                            <a href="mailto:{{ student.email }}">{{ student.email }}</a>
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted"><strong>Date of Birth:</strong></td>
                        <td>
                            {% if student.dateOfBirth %}
                                {{ student.dateOfBirth|date('F j, Y') }}
                                <span class="text-muted">({{ student.dateOfBirth|date('Y-m-d') }})</span>
                            {% else %}
                                <span class="text-muted">Not provided</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted"><strong>Department:</strong></td>
                        <td>
                            {% if student.department %}
                                <a href="{{ path('department_show', {id: student.department.id}) }}">
                                    {{ student.department.name }} 
                                    <span class="badge bg-info">{{ student.department.code }}</span>
                                </a>
                            {% else %}
                                <span class="text-muted">Not assigned</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted"><strong>Registered:</strong></td>
                        <td>{{ student.createdAt|date('Y-m-d H:i:s') }}</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    {# Enrollments Card #}
    <div class="col-lg-6 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Course Enrollments</h5>
            </div>
            <div class="card-body">
                {% if student.enrollments is empty %}
                    <p class="text-muted">This student is not enrolled in any courses yet.</p>
                    {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('enrollment_new') }}" class="btn btn-sm btn-success">
                        <i class="bi bi-plus-circle"></i> Enroll in a Course
                    </a>
                    {% endif %}
                {% else %}
                    <div class="list-group">
                        {% for enrollment in student.enrollments %}
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">
                                        <a href="{{ path('course_show', {id: enrollment.course.id}) }}">
                                            {{ enrollment.course.name }}
                                        </a>
                                    </h6>
                                    <small class="text-muted">
                                        Code: {{ enrollment.course.code }} | 
                                        Credits: {{ enrollment.course.credits }}
                                    </small>
                                </div>
                                <div>
                                    {% if enrollment.status == 'active' %}
                                        <span class="badge bg-primary">Active</span>
                                    {% elseif enrollment.status == 'completed' %}
                                        <span class="badge bg-success">Completed</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ enrollment.status|title }}</span>
                                    {% endif %}
                                    
                                    {% if enrollment.grade %}
                                        <span class="badge bg-info">Grade: {{ enrollment.grade|number_format(1) }}</span>
                                    {% endif %}
                                </div>
                            </div>
                            <small class="text-muted">
                                Enrolled: {{ enrollment.enrolledAt|date('Y-m-d') }}
                            </small>
                        </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{# Delete Confirmation Modal #}
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong>{{ student.firstName }} {{ student.lastName }}</strong>?</p>
                <p class="text-danger">
                    <i class="bi bi-exclamation-triangle"></i> 
                    This action cannot be undone. All enrollments will also be deleted.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form method="post" action="{{ path('student_delete', {id: student.id}) }}" style="display: inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ student.id) }}">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete Student
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}