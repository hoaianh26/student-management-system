{{ form_start(form) }}
    <div class="row">
        <div class="col-md-6 mb-3">
            {{ form_row(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Enter course name'}}) }}
        </div>
        <div class="col-md-3 mb-3">
            {{ form_row(form.code, {'attr': {'class': 'form-control', 'placeholder': 'CS101'}}) }}
        </div>
        <div class="col-md-3 mb-3">
            {{ form_row(form.credits, {'attr': {'class': 'form-control', 'min': 1, 'max': 10}}) }}
            <div class="form-text small text-muted">Range: 1 to 10 credits</div>
        </div>
        <div class="col-md-12 mb-3">
            {# Thêm class select2 vào ô chọn department #}
            {{ form_row(form.department, {'attr': {'class': 'form-select select2', 'data-placeholder': 'Select Department'}}) }}
        </div>
        <div class="col-12 mb-3">
            {{ form_row(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
        </div>
    </div>
    <div class="d-flex justify-content-end gap-2 mt-3">
        <a href="{{ path('course_index') }}" class="btn btn-secondary">Cancel</a>
        <button class="btn btn-warning">
            <i class="bi bi-check-circle"></i> {{ button_label|default('Save Changes') }}
        </button>
    </div>
{{ form_end(form) }}

<script>
    // Đảm bảo jQuery và Select2 đã sẵn sàng trước khi chạy
    (function checkSelect2() {
        if (window.jQuery && jQuery.fn.select2) {
            $('.select2').select2({
                theme: 'bootstrap-5',
                width: '100%',
                placeholder: 'Type to search...',
                allowClear: true
            });
        } else {
            setTimeout(checkSelect2, 50);
        }
    })();
</script>
