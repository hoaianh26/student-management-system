{% extends 'base.html.twig' %}

{% block title %}Courses - Student Management System{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-book"></i> Courses</h1>
    {% if is_granted('ROLE_ADMIN') %}
    <a href="{{ path('course_new') }}" class="btn btn-warning">
        <i class="bi bi-plus-circle"></i> Add New Course
    </a>
    {% endif %}
</div>

{% if courses is empty %}
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No courses found.
    </div>
{% else %}
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Code</th>
                            <th>Course Name</th>
                            <th>Credits</th>
                            <th>Department</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for course in courses %}
                        <tr>
                            <td><span class="badge bg-info">{{ course.code }}</span></td>
                            <td><strong>{{ course.name }}</strong></td>
                            <td>{{ course.credits }}</td>
                            <td>
                                {% if course.department %}
                                    <a href="{{ path('department_show', {id: course.department.id}) }}" class="text-decoration-none">
                                        {{ course.department.name }}
                                    </a>
                                {% else %}
                                    <span class="text-muted">N/A</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="btn-group">
                                    <a href="{{ path('course_show', {id: course.id}) }}" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    {% if is_granted('ROLE_ADMIN') %}
                                    <a href="{{ path('course_edit', {id: course.id}) }}" class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endif %}
{% endblock %}
