{% extends 'base.html.twig' %}

{% block title %}Edit Enrollment{% endblock %}

{% block body %}
<div class="card shadow-sm border-0">
    <div class="card-header bg-warning py-3">
        <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Edit Enrollment</h4>
    </div>
    <div class="card-body p-4">
        {{ form_start(form) }}
            <div class="row">
                <div class="col-md-6 mb-3">
                    {{ form_row(form.student) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_row(form.course) }}
                </div>
                <div class="col-md-4 mb-3">
                    {{ form_row(form.enrolledAt) }}
                </div>
                <div class="col-md-4 mb-3">
                    {{ form_row(form.status) }}
                </div>
                <div class="col-md-4 mb-3">
                    {{ form_row(form.grade) }}
                </div>
            </div>
            <div class="d-flex justify-content-end gap-2 mt-3">
                <a href="{{ path('enrollment_index') }}" class="btn btn-secondary">Cancel</a>
                <button class="btn btn-warning">Save Changes</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
